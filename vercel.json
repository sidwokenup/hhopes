{
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 10
    },
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "server.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/send-email",
      "methods": ["POST"],
      "dest": "/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}